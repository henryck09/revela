# Datos de tu proyecto Supabase (Settings > API)
VITE_SUPABASE_URL=https://TUPROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Tu número de WhatsApp (el del negocio, donde te llegan las capturas de pago)
# Formato: código de país + número, sin espacios ni "+" (ej: Ecuador 593987654321)
VITE_WHATSAPP_NUMBER=593987654321

# URL pública donde queda desplegado el sitio (la que da Vercel, o tu dominio propio)
VITE_SITE_URL=https://tu-proyecto.vercel.app
